usethis::use_gpl3_license()
#' Generate Archipelagic Spatial Weights
#'
#' Converts fragmented island maps into 100% connected spatial weights
#' using KNN-5 logic to eliminate isolated provinces.
#'
#' @param p_map An sf object (the map)
#' @return A listw object (the spatial weights)
#' @export
build_archipelago_weights <- function(p_map) {
# 1. Extraction of spatial coordinates
coords <- sf::st_coordinates(sf::st_centroid(sf::st_geometry(p_map)))
coords_numeric <- as.matrix(coords[, 1:2])
# 2. The Bridge Logic: K-Nearest Neighbors (K=5)
# Fixes the 16 isolated provinces found in Queen models
nb <- spdep::knn2nb(spdep::knearneigh(coords_numeric, k = 5))
# 3. Standardization
w_list <- spdep::nb2listw(nb, style = "W")
return(w_list)
}
