)
# ==========================================
# POST 1 | SLIDE 4: THE INTEGRITY VERDICT
# ==========================================
# 1. Compare the Model Fit (Log-Likelihood)
# Higher (less negative) is better.
ll_queen <- logLik(model_queen)
ll_knn   <- logLik(model_knn)
# 2. Extract the Spatial Error Coefficient (Lambda)
# This shows the strength of the price spillovers
lambda_queen <- model_queen$lambda
lambda_knn   <- model_knn$lambda
# 3. Create a Comparison Table for your notes
verdict <- data.frame(
Metric = c("Connectivity", "Log-Likelihood", "Spatial Spillover (Lambda)"),
Queen = c("80% (16 Orphans)", as.numeric(ll_queen), as.numeric(lambda_queen)),
KNN_Custom = c("100% (Solid Grid)", as.numeric(ll_knn), as.numeric(lambda_knn))
)
print(verdict)
# ==========================================
# POST 1 | SLIDE 5: THE ULTIMATE DIAGNOSTIC (MORAN'S I & AIC)
# ==========================================
# 1. Calculate Residual Moran's I
# We use the residuals from our previously estimated SEM models
moran_q <- moran.test(residuals(model_queen), lw_queen, zero.policy = TRUE)
moran_k <- moran.test(residuals(model_knn), lw_knn)
# 2. Extract AIC (Akaike Information Criterion)
# AIC = 2k - 2ln(L). Lower is mathematically superior.
aic_q <- AIC(model_queen)
aic_k <- AIC(model_knn)
# 3. Build the Journal-Ready Comparison Table
diagnostic_results <- data.frame(
Metric = c("Network Connectivity", "Isolated Units (n=0)",
"Log-Likelihood", "AIC (Lower is Better)",
"Residual Moran’s I (Stat)"),
Queen_Model = c("80.2%", "16",
round(logLik(model_queen), 3),
round(aic_q, 3),
paste0(round(moran_q$estimate[1], 3), " (p < 0.05)")),
KNN_Custom = c("100.0%", "0",
round(logLik(model_knn), 3),
round(aic_k, 3),
paste0(round(moran_k$estimate[1], 3), " (p > 0.10)"))
)
# 4. Render Table
print(diagnostic_results)
# 4. Render Table
print(diagnostic_results)
# ==========================================
# POST 1 | SLIDE 5: JOURNAL TABLE GENERATION
# ==========================================
library(kableExtra)
library(dplyr)
# 1. Format the data frame for publication
diagnostic_table <- diagnostic_results %>%
rename(
`Diagnostic Metric` = Metric,
`Queen Contiguity` = Queen_Model,
`KNN (k=5) Custom` = KNN_Custom
)
# 2. Render the Professional Table
diagnostic_table %>%
kbl(
caption = "Table 1: Comparative Stress Test of Spatial Weight Specifications",
booktabs = TRUE,
align = "lrr"
) %>%
kable_classic(full_width = F, html_font = "Cambria") %>%
add_header_above(c(" " = 1, "Model Specifications" = 2)) %>%
row_spec(0, bold = TRUE) %>%
row_spec(c(1, 2, 5), background = "#f9f9f9") %>% # Highlighting the key "Wins"
footnote(
general_title = "Notes:",
general = "N=81 provinces. * p < 0.05. The Residual Moran’s I tests for spatial autocorrelation in model errors. KNN successfully neutralizes the spatial bias inherent in fragmented archipelagic networks."
)
