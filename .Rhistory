usethis::use_test( "connectivity")
test_that("Archipelago connectivity reaches 100% (nc=1)", {
# This test ensures the KNN k=5 bridge is functioning.
# Based on research, Queen logic would fail here with nc=16.
weights <- build_archipelago_weight(raw_data, k = 5)
# The "Beast" Metric: We expect exactly 1 connected component.
expect_equal(spdep::n.comp.nb(weights$neighbours)$nc, 1)
})
